# stock_1901 — environment variables example
# Copy to .env and fill in real values.
# Never commit .env to version control.

# ── Data Provider ─────────────────────────────────────────────────────────────
# STOCK1901_KRX_UNIVERSE: comma-separated KRX tickers for daily_krx_flow
STOCK1901_KRX_UNIVERSE=005930,000660,035420,035720,051910

# ── Quant1901 Auxiliary Backtest ──────────────────────────────────────────────
# Tickers to process in quant1901_daily_flow (with .KS/.KQ suffix)
QUANT1901_UNIVERSE=005930.KS,000660.KS,035420.KS

# Lookback period for OHLCV data (e.g. 1y, 2y, 3y)
QUANT1901_PERIOD=2y

# Set to true to enable EMA grid search (slow — adds ~2 min per ticker)
QUANT1901_OPTIMIZE=false

# Output directory for daily snapshot JSON files
QUANT1901_OUTPUT_DIR=reports/quant1901/daily

# ── Prefect ───────────────────────────────────────────────────────────────────
# Prefect server URL (leave empty for local ephemeral server)
# PREFECT_API_URL=http://localhost:4200/api

# ── MLflow ────────────────────────────────────────────────────────────────────
# MLflow tracking server URI (leave empty for local file store ./mlruns)
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── Forward Tracking ──────────────────────────────────────────────────────────
# Set to false to disable AutoForwardRecorder in daily_krx_flow
FORWARD_TRACKING_ENABLED=true

# ── RD-Agent ──────────────────────────────────────────────────────────────────
RDAGENT_ENABLED=false
# RDAGENT_DOCKER_IMAGE=microsoft/rdagent:latest
# RDAGENT_BUDGET_USD=10.0
# RDAGENT_CYCLES=2
# RDAGENT_TIMEOUT_MIN=30
RDAGENT_APPROVAL_REQUIRED=true

# ── Broker Adapters (paper-only by default) ────────────────────────────────────
# Never set live broker credentials unless you explicitly intend live trading.
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# KIS_APP_KEY=
# KIS_APP_SECRET=
