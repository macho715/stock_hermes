      "id": 1,
      "title": "Recommendation latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "ms"},
        "overrides": []
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(stock1901_recommendation_latency_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(stock1901_recommendation_latency_ms_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(stock1901_recommendation_latency_ms_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "title": "Gate verdict counts (stacked) by track,verdict",
      "type": "barchart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
